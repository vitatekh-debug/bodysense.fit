# Hace que pnpm instale con una estructura flat de node_modules
# (igual a npm/yarn) en lugar del virtual store con symlinks.
# Esto es necesario para que Netlify pueda resolver módulos
# transitivos de Next.js (styled-jsx, react-server-dom, etc.)
# al empaquetar las funciones de SSR.
node-linker=node-modules

# Eleva automáticamente styled-jsx al nivel raíz por si acaso
public-hoist-pattern[]=*styled-jsx*
