# Hoisita todos los paquetes al node_modules raíz (como npm/yarn).
# Necesario para que Netlify pueda resolver módulos transitivos de Next.js
# (styled-jsx, react-server-dom, etc.) al empaquetar funciones SSR.
# Menos estricto que pnpm puro pero sin romper la estructura de workspaces.
shamefully-hoist=true

# Hoisita explícitamente styled-jsx (dependencia interna de Next.js 14)
public-hoist-pattern[]=*styled-jsx*
