{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "_comment_dashboard": [
    "⚠️  PASO OBLIGATORIO EN VERCEL DASHBOARD (no configurable aquí):",
    "   Project Settings → General → Root Directory = apps/web",
    "   Sin esto el adaptador Next.js de Vercel no detecta el framework.",
    "   Después de cambiarlo, Vercel re-hace el build automáticamente."
  ],

  "framework": "nextjs",

  "installCommand": "pnpm install --frozen-lockfile",

  "buildCommand": "pnpm turbo run build --filter=@vitatekh/web",

  "outputDirectory": "apps/web/.next",

  "devCommand": "pnpm turbo run dev --filter=@vitatekh/web",

  "headers": [
    {
      "_comment": "HTML y rutas: nunca servir stale desde CDN o browser",
      "source": "/((?!_next/static|_next/image|favicon\\.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp|ico|txt|xml)$).*)",
      "headers": [
        { "key": "Cache-Control",           "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "_comment": "Chunks JS/CSS: nombre lleva hash de contenido → immutable 1 año",
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "_comment": "Imágenes optimizadas por next/image",
      "source": "/_next/image(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "_comment": "Assets públicos estáticos (fuentes, logos, etc.)",
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],

  "rewrites": [
    {
      "_comment": "Permite que el middleware de Next.js maneje todas las rutas internamente",
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
